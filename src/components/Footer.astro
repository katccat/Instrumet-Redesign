---
import { site, nav } from "@/config/site.js";
const { address } = site.contact;
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-muted">
  <div
    class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-4 lg:px-8"
  >
    {/* Brand + address */}
    <div class="lg:col-span-2">
      <div class="flex items-center gap-3">
        <img src="/logo.svg" alt="" width="32" height="32" class="h-8 w-8" />
        <span class="text-lg font-bold tracking-tight text-foreground"
          >{site.wordmark}</span
        >
      </div>
      <address class="mt-4 not-italic text-sm leading-relaxed text-muted-foreground">
        {site.companyName}<br />
        {address.street}<br />
        {address.city}, {address.state} {address.zip}
      </address>
      <dl class="mt-4 space-y-1 text-sm text-muted-foreground">
        <div class="flex gap-2">
          <dt class="font-medium text-foreground">Phone</dt>
          <dd><a href={site.contact.phoneHref} class="hover:text-accent">{site.contact.phone}</a></dd>
        </div>
        <div class="flex gap-2">
          <dt class="font-medium text-foreground">Email</dt>
          <dd><a href={`mailto:${site.contact.email}`} class="hover:text-accent">{site.contact.email}</a></dd>
        </div>
        <div class="flex gap-2">
          <dt class="font-medium text-foreground">Fax</dt>
          <dd>{site.contact.fax}</dd>
        </div>
      </dl>
    </div>

    {/* Useful links */}
    <nav aria-label="Footer">
      <h2 class="text-sm font-semibold text-foreground">Explore</h2>
      <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
        {nav.map((item) => (
          <li>
            <a href={item.href} class="hover:text-accent">{item.label}</a>
          </li>
        ))}
        <li><a href="/contact" class="hover:text-accent">Contact</a></li>
      </ul>
    </nav>

    {/* Follow us */}
    <div>
      <h2 class="text-sm font-semibold text-foreground">Follow us</h2>
      <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
        {site.social.map((s) => (
          <li>
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="hover:text-accent">{s.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-border">
    <div
      class="mx-auto max-w-7xl px-4 py-6 text-xs text-muted-foreground sm:px-6 lg:px-8"
    >
      © {year} {site.companyName}. All rights reserved.
    </div>
  </div>
</footer>
