---
import { site, nav } from "@/config.js";
const { address } = site.contact;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-container site-footer__grid">
    {/* Brand + address */}
    <div class="site-footer__brand">
      <div class="footer-brand">
        <img src="/logo.svg" alt="" width="32" height="32" class="footer-brand__logo" />
        <span class="brand__name">{site.wordmark}</span>
      </div>
      <address class="footer-address">
        {site.companyName}<br />
        {address.street}<br />
        {address.city}, {address.state} {address.zip}
      </address>
      <dl class="footer-contact">
        <div class="footer-contact__row">
          <dt class="footer-contact__label">Phone</dt>
          <dd><a href={site.contact.phoneHref} class="footer-link">{site.contact.phone}</a></dd>
        </div>
        <div class="footer-contact__row">
          <dt class="footer-contact__label">Email</dt>
          <dd><a href={`mailto:${site.contact.email}`} class="footer-link">{site.contact.email}</a></dd>
        </div>
        <div class="footer-contact__row">
          <dt class="footer-contact__label">Fax</dt>
          <dd>{site.contact.fax}</dd>
        </div>
      </dl>
    </div>

    {/* Useful links */}
    <nav aria-label="Footer">
      <h2 class="footer-heading">Explore</h2>
      <ul class="footer-links">
        {nav.map((item) => (
          <li>
            <a href={item.href} class="footer-link">{item.label}</a>
          </li>
        ))}
        <li><a href="/contact" class="footer-link">Contact</a></li>
      </ul>
    </nav>

    {/* Follow us */}
    <div>
      <h2 class="footer-heading">Follow us</h2>
      <ul class="footer-links">
        {site.social.map((s) => (
          <li>
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="footer-link">{s.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="site-container site-footer__copy">
      © {year} {site.companyName}. All rights reserved.
    </div>
  </div>
</footer>
