---
import SiteNav from "@/components/nav/SiteNav.tsx";
import { site, nav } from "@/config.js";
---

<header class="site-header">
  {/* Upper tier */}
  <div class="site-header__tier">
    <div class="site-container site-header__bar">
      <a href="/" class="brand" aria-label={`${site.wordmark} home`}>
        <img src="/logo.svg" alt="" width="36" height="36" class="brand__logo" />
        <span class="brand__text">
          <span class="brand__name">{site.wordmark}</span>
          <span class="brand__tagline">{site.tagline}</span>
        </span>
      </a>

      <div class="site-header__actions">
        <a href={site.contact.phoneHref} class="site-header__phone"
          >{site.contact.phone}</a
        >
        <a href="/contact" class="btn btn--sm btn--primary">Contact</a>
      </div>
    </div>
  </div>

  {/* Lower tier — interactive nav island (mega-menu + mobile hamburger) */}
  <div class="site-header__tier">
    <SiteNav nav={nav} client:load />
  </div>
</header>
