---
// Renders a real image when `src` is provided; otherwise a clearly labeled
// placeholder block (no generated/placeholder imagery — per the brief).
const {
  src,
  alt = "",
  label = "photo",
  class: className,
  loading = "lazy",
} = Astro.props;
---

{
  src ? (
    <img
      src={src}
      alt={alt}
      loading={loading}
      decoding="async"
      class:list={["media-img", className]}
    />
  ) : (
    <div
      class:list={["media-placeholder", className]}
      role="img"
      aria-label={`Placeholder image: ${label}`}
    >
      Image: {label}
    </div>
  )
}
