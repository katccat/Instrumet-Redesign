---
// Eyebrow/kicker + title + optional intro. Eyebrow is styled but NOT fully
// uppercase (small caps-ish treatment via tracking + accent color).
import { cn } from "@/lib/utils";
const { eyebrow, title, intro, align = "left", class: className } = Astro.props;
---

<div
  class={cn(
    "max-w-3xl",
    align === "center" && "mx-auto text-center",
    className
  )}
>
  {
    eyebrow && (
      <p class="mb-3 text-sm font-semibold tracking-wide text-accent">
        {eyebrow}
      </p>
    )
  }
  {
    title && (
      <h2 class="text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
        {title}
      </h2>
    )
  }
  {intro && <p class="mt-4 text-lg text-muted-foreground">{intro}</p>}
  <slot />
</div>
