---
// Articles section (ref: articles.png): big heading, a left column of dated
// article links separated by hairlines, and a large featured image at right.
import { getCollection } from "astro:content";
import Media from "@/components/Media.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featured = posts[0];
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" });
---

<section class="section">
  <div class="site-container section-inner">
    <div class="articles-preview">
      {/* Left: heading + list */}
      <div>
        <div class="articles-preview__head">
          <h2 class="section-title">Latest News &amp; Resources</h2>
          <a href="/articles" class="articles-preview__all">All articles</a>
        </div>

        <ul class="article-list">
          {
            posts.map((post) => (
              <li>
                <a href={`/articles/${post.id}`} class="article-list__link">
                  <p class="article-list__date">{fmt(post.data.pubDate)}</p>
                  <h3 class="article-list__title">{post.data.title}</h3>
                </a>
              </li>
            ))
          }
        </ul>
        <a href="/articles" class="articles-preview__all--mobile">All articles</a>
      </div>

      {/* Right: featured image */}
      <div class="order-flip">
        <a href={featured ? `/articles/${featured.id}` : "/articles"} class="block-fill">
          <div class="frame frame--4-3 fill-height">
            <Media
              src={featured?.data.heroImage}
              alt={featured?.data.title || ""}
              label="article photo"
            />
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
