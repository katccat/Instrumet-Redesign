---
import SectionHeading from "./SectionHeading.astro";
import Icon from "@/components/icons/Icon.astro";

// Certifications & standards. Rendered as text badges (not fabricated logos)
// so nothing is invented. Every item below appears in the source site.
const standards = [
  { code: "A2LA", note: "Accredited Lab" },
  { code: "ISO/IEC 17025", note: "Calibration" },
  { code: "ASTM E4", note: "Force" },
  { code: "ISO 7500-1", note: "Force" },
  { code: "ASTM E83", note: "Extensometer" },
  { code: "ISO 9513", note: "Extensometer" },
  { code: "ASTM E2309", note: "Displacement" },
  { code: "ASTM E2658", note: "Crosshead Speed" },
];
---

<section class="border-t border-border bg-background py-20 lg:py-24">
  <div class="container">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12">
      <!-- Compliance statement -->
      <div class="lg:col-span-4">
        <SectionHeading
          eyebrow="Compliance"
          title="Certifications & Standards"
        />
        <p class="mt-5 text-base leading-relaxed text-muted-foreground">
          Instru-Met is proud to be an A2LA-accredited laboratory in the field
          of calibration. Our engineers perform force verification (compression
          and tension), extensometer and displacement calibration, and
          crosshead-speed verification to recognized ASTM and ISO methods.
        </p>
        <ul class="mt-6 space-y-2.5 text-sm">
          <li class="flex items-start gap-2">
            <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-primary" />
            Force verification to ASTM E4 and ISO 7500-1
          </li>
          <li class="flex items-start gap-2">
            <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-primary" />
            Extensometer and displacement to ASTM E83, ISO 9513, ASTM E2309
          </li>
          <li class="flex items-start gap-2">
            <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-primary" />
            Crosshead speed to ASTM E2658
          </li>
        </ul>
      </div>

      <!-- Badge row -->
      <div class="lg:col-span-8">
        <ul class="grid grid-cols-2 gap-px overflow-hidden border border-border bg-border sm:grid-cols-4">
          {
            standards.map((s) => (
              <li class="flex aspect-[4/3] flex-col items-center justify-center gap-1 bg-background p-4 text-center">
                <span class="tabular text-lg font-bold tracking-tight text-primary">{s.code}</span>
                <span class="text-xs uppercase tracking-wide text-muted-foreground">{s.note}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
