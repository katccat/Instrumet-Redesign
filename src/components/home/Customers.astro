---
// Customers served — a grid of customer logos (ref: logo-array.png).
// Only NASA ships as a real logo asset; the others render as clean wordmarks
// (names supplied by the brief). No fabricated logo imagery is generated.
import SectionHeading from "@/components/SectionHeading.astro";

const customers = [
  { name: "NASA", logo: "/logos/nasa.webp" },
  { name: "Lockheed Martin", logo: "/logos/lockheed-martin.webp" },
  { name: "Gorilla Glue", logo: "/logos/gorilla-glue.png" },
  { name: "Polo", logo: "/logos/ralph-lauren.png" },
  { name: "Intuitive", logo: "/logos/intuitive.webp" },
];
---

<section class="border-b border-border">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <SectionHeading
      eyebrow="Hello"
      title="Trusted across many industries"
    />
    <ul
      class="mt-12 grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-5"
    >
      {
        customers.map((c) => (
          <li class="flex h-28 items-center justify-center px-6">
            {c.logo ? (
              <img
                src={c.logo}
                alt={c.name}
                class="max-h-20 w-auto transition hover:opacity-80 hover:grayscale-0"
              />
            ) : (
              <span class="text-center text-lg font-semibold tracking-tight text-muted-foreground transition-colors hover:text-foreground">
                {c.name}
              </span>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>
