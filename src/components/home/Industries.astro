---
import { getCollection } from "astro:content";
import SectionHeading from "./SectionHeading.astro";
import Icon from "@/components/icons/Icon.astro";

// Industries grid from the `industries` collection: icon + short label each.
const industries = (
  await getCollection("industries", ({ data }) => !data.draft)
).sort((a, b) => a.data.order - b.data.order);
---

<section class="border-t border-border bg-secondary py-20 lg:py-24">
  <div class="container">
    <SectionHeading
      eyebrow="Who We Serve"
      title="Industries Served"
      intro="On-site calibration and service for regulated, industrial, and research laboratories."
    />

    <ul class="mt-12 grid grid-cols-2 gap-px overflow-hidden border border-border bg-border sm:grid-cols-3 lg:grid-cols-4">
      {
        industries.map((industry) => (
          <li class="bg-background">
            <a
              href={`/industries/${industry.id}`}
              class="group flex items-center gap-4 p-6 transition-colors hover:bg-secondary"
            >
              <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center text-primary">
                <Icon name={industry.data.icon} class="h-6 w-6" />
              </span>
              <span class="text-sm font-medium leading-tight text-foreground group-hover:text-primary">
                {industry.data.label}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
