---
import { getCollection } from "astro:content";
import SectionHeading from "./SectionHeading.astro";
import { formatDate } from "@/lib/utils";

// Recent news: three most recent non-draft posts, newest first.
const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section class="border-t border-border bg-background py-20 lg:py-24">
  <div class="container">
    <SectionHeading
      eyebrow="Latest News"
      title="News & Insights"
      intro="Calibration guidance, equipment spotlights, and service updates from our engineers."
      linkHref="/news"
      linkLabel="View all"
    />

    <ul class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        posts.map((post) => (
          <li>
            <a
              href={`/news/${post.id}`}
              class="group flex h-full flex-col border border-border bg-card transition-shadow hover:shadow-card-hover"
            >
              <div class="aspect-[16/10] overflow-hidden bg-secondary">
                <img
                  src={post.data.cover ?? "/images/post-calibration.svg"}
                  alt={post.data.coverAlt}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="mb-3 flex items-center gap-3 text-xs">
                  <span class="bg-primary px-2 py-1 font-semibold uppercase tracking-wide text-primary-foreground">
                    {post.data.category}
                  </span>
                  <time datetime={post.data.date.toISOString()} class="tabular text-muted-foreground">
                    {formatDate(post.data.date)}
                  </time>
                </div>
                <h3 class="text-lg font-semibold leading-snug tracking-tight group-hover:text-primary">
                  {post.data.title}
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">
                  {post.data.excerpt}
                </p>
                <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold uppercase tracking-wide text-primary">
                  Read more
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
