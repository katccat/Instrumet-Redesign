---
// Shared section header: eyebrow + title + optional intro + optional link.
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
  linkHref?: string;
  linkLabel?: string;
}
const { eyebrow, title, intro, linkHref, linkLabel } = Astro.props;
---

<div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
  <div class="max-w-2xl">
    <p class="eyebrow mb-3">{eyebrow}</p>
    <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">{title}</h2>
    {intro && <p class="mt-4 text-base leading-relaxed text-muted-foreground">{intro}</p>}
  </div>
  {
    linkHref && linkLabel && (
      <a
        href={linkHref}
        class="group inline-flex shrink-0 items-center gap-1.5 text-sm font-semibold uppercase tracking-wide text-primary"
      >
        {linkLabel}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    )
  }
</div>
