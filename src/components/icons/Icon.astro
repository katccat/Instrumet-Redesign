---
/*
  Single inline-SVG icon component. Icons are line-style (stroke, no fill) to
  match the restrained scientific aesthetic. Referenced by key from content
  frontmatter (e.g. industry `icon: "aerospace"`) so editors never touch SVG.

  All paths use currentColor so color is controlled by the parent's text color.
*/
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = "" } = Astro.props;

// 24x24 viewBox, 1.5 stroke. Keep keys stable: content files reference them.
const paths: Record<string, string> = {
  // Industries
  aerospace: '<path d="M2 16l20-6-9 12-2-5-9-1z"/><path d="M11 17l3-3"/>',
  automotive:
    '<path d="M5 13l1.5-4.5A2 2 0 0 1 8.4 7h7.2a2 2 0 0 1 1.9 1.5L19 13"/><path d="M3 13h18v4H3z"/><circle cx="7.5" cy="17.5" r="1.5"/><circle cx="16.5" cy="17.5" r="1.5"/>',
  medical:
    '<path d="M12 5v14M5 12h14"/><rect x="3" y="3" width="18" height="18" rx="0"/>',
  food:
    '<path d="M6 3v7a3 3 0 0 0 6 0V3M9 3v18M17 3c-1.5 1-2 3-2 6s.5 5 2 6V3z"/>',
  plastics:
    '<path d="M8 3h8l-1 4H9L8 3z"/><path d="M9 7c-2 3-3 7-3 10a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3c0-3-1-7-3-10"/>',
  rubber:
    '<circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3"/>',
  textiles:
    '<path d="M4 6h16M4 6v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6"/><path d="M8 6v14M12 6v14M16 6v14"/>',
  research:
    '<path d="M9 3h6M10 3v6l-5 8a2 2 0 0 0 2 3h10a2 2 0 0 0 2-3l-5-8V3"/>',
  academia:
    '<path d="M12 4L2 9l10 5 10-5-10-5z"/><path d="M6 11v5c0 1 3 2 6 2s6-1 6-2v-5"/>',
  pharma:
    '<rect x="4" y="9" width="16" height="11"/><path d="M7 9V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v3M12 12v5M9.5 14.5h5"/>',

  // UI / product
  frame:
    '<rect x="5" y="3" width="14" height="18"/><path d="M5 9h14M5 15h14M9 3v18"/>',
  loadcell:
    '<circle cx="12" cy="12" r="7"/><path d="M12 5v3M12 16v3M5 12h3M16 12h3"/>',
  grip:
    '<path d="M8 3v6l-2 2v6a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-6l-2-2V3"/><path d="M8 9h8"/>',
  extensometer:
    '<path d="M4 8h16M4 16h16M8 8v8M16 8v8"/><path d="M4 6v4M20 6v4M4 14v4M20 14v4"/>',
  calibration:
    '<path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/><circle cx="12" cy="12" r="3"/>',
  repair:
    '<path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.1-2.1 2.5-2.5z"/>',

  // Misc
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  phone:
    '<path d="M4 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L20 13l1 4v3a1 1 0 0 1-1 1A16 16 0 0 1 4 5a1 1 0 0 1 0-1z"/>',
  mail: '<rect x="3" y="5" width="18" height="14"/><path d="M3 6l9 7 9-7"/>',
  pin: '<path d="M12 21s7-6.5 7-12a7 7 0 1 0-14 0c0 5.5 7 12 7 12z"/><circle cx="12" cy="9" r="2.5"/>',
  check: '<path d="M20 6L9 17l-5-5"/>',
};

const d = paths[name] ?? paths.check;
---

<svg
  class={className}
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={d}
/>
