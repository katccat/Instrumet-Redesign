---
// Static button/link with no client JS. Renders <a> when `href` is set,
// otherwise <button>. Appearance lives in ui.css (.btn / .btn--*).
const {
  href,
  variant = "primary",
  size = "md",
  class: className,
  ...rest
} = Astro.props;

// Back-compat with the old shadcn-style prop values.
const variantAlias = { default: "primary" };
const sizeAlias = { default: "md" };
const v = variantAlias[variant] ?? variant;
const s = sizeAlias[size] ?? size;

const Button = href ? "a" : "button";
---

<Button class:list={["btn", `btn--${v}`, `btn--${s}`, className]} href={href} {...rest}>
  <slot />
</Button>
