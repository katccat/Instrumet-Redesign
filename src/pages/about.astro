---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Media from "@/components/Media.astro";
import Button from "@/components/ui/Button.astro";
import { site } from "@/config.js";

const years = new Date().getFullYear() - site.foundedYear;

const facts = [
  { label: "Founded", value: site.foundedYear.toString() },
  { label: "Years of service", value: `${years}+` },
  { label: "Ownership", value: "American owned & operated" },
  { label: "Headquarters", value: "Union, NJ" },
];

const brands = [
  "Instron",
  "Tinius Olsen",
  "Baldwin",
  "Thwing Albert",
  "Monsanto",
  "United",
];
const industries = [
  "Textile",
  "Medical",
  "Plastics",
  "Wire & metal",
  "Aerospace",
  "Government",
  "Consumer products",
];
---

<BaseLayout
  title="About"
  description="Founded in 1974, Instru-Met Corporation remanufactures, repairs, and calibrates Instron and other testing equipment from its Union, NJ facility."
>
  <section class="section section--muted">
    <div class="site-container page-header">
      <p class="eyebrow">About us</p>
      <h1 class="page-header__title">
        Keeping classic testing machines accurate since {site.foundedYear}
      </h1>
      <p class="page-header__intro">
        {site.companyName} specializes in remanufactured and upgraded Instron load frames — privately held and American owned &amp; operated from day one.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="site-container section-grid">
      <div>
        <div class="frame frame--4-3">
          <Media src="/images/load-cell-repair.jpg" alt="Load cell repair at Instru-Met, Union NJ" label="workshop photo" />
        </div>
      </div>

      <div class="content-stack">
        <p>
          We provide accredited tension/compression calibration for load cells,
          extensometers, temperature, crosshead speed, and displacement, plus
          accredited dimensional calibration for calipers and micrometers.
        </p>
        <p>
          We maintain a large inventory of hard-to-find parts for frames that are
          no longer produced, and we service Instron frames from 1946 to the
          present — including Models 1000, 1120, 1130, 4200, 4300, and 4500 Series.
        </p>
        <p>
          Our staff includes engineers, technicians, and machinists, and our
          quality system is compliant with ISO/IEC 17025 and ANSI/NCSL Z540-1.
        </p>

        <div>
          <h2 class="eyebrow">Brands we service</h2>
          <div class="chip-row">
            {brands.map((b) => (
              <span class="chip">{b}</span>
            ))}
          </div>
        </div>

        <div>
          <h2 class="eyebrow">Industries we serve</h2>
          <div class="chip-row">
            {industries.map((i) => (
              <span class="chip">{i}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="site-container cta-band__inner">
      <p class="cta-band__text">Work with a team that supports your equipment for life.</p>
      <Button href="/contact">Get in touch</Button>
    </div>
  </section>
</BaseLayout>
