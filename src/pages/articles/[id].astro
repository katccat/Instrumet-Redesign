---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Media from "@/components/Media.astro";
import { getYouTubeId, getYouTubeEmbed } from "@/lib/youtube";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// When the post has a video, embed the player in the hero slot (falling back to
// the static image if it isn't a recognizable YouTube URL).
const ytId = post.data.videoUrl ? getYouTubeId(post.data.videoUrl) : null;
const fmt = (d) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" });
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="section">
    <div class="site-container article">
      <a href="/articles" class="article__back">← All articles</a>
      <p class="article__meta">{fmt(post.data.pubDate)}</p>
      <h1 class="article__title">{post.data.title}</h1>
      {
        post.data.tags && (
          <div class="tag-row article__tags">
            {post.data.tags.map((t) => (
              <a class="tag" href={`/articles/?tag=${encodeURIComponent(t)}`}>
                {t}
              </a>
            ))}
          </div>
        )
      }

      <div class="frame frame--16-9 article__hero">
        {
          ytId ? (
            <iframe
              class="article__video"
              src={getYouTubeEmbed(ytId)}
              title={post.data.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          ) : (
            <Media src={post.data.heroImage} alt={post.data.title} label="article photo" loading="eager" />
          )
        }
      </div>

      <div class="prose article__body">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
