---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Media from "@/components/Media.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" });
---

<BaseLayout
  title="Articles"
  description="News, guides, and product write-ups from Instru-Met Corporation."
>
  <section class="section section--muted">
    <div class="site-container page-header">
      <p class="eyebrow">Articles</p>
      <h1 class="page-header__title">Latest News &amp; Resources</h1>
      <p class="page-header__intro">
        Guides, product write-ups, and news from our engineers.
      </p>
    </div>
  </section>

  <section>
    <div class="site-container section-inner">
      <div class="card-grid">
        {
          posts.map((post) => (
            <article class="card">
              <a href={`/articles/${post.id}`} class="card__media">
                <Media src={post.data.heroImage} alt={post.data.title} label="article photo" />
              </a>
              <div class="card__body">
                <p class="card__meta">{fmt(post.data.pubDate)}</p>
                <h2 class="card__title">
                  <a href={`/articles/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="card__text">{post.data.description}</p>
                {post.data.tags && (
                  <div class="tag-row card__tags">
                    {post.data.tags.slice(0, 3).map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
