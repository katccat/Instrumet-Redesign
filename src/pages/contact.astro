---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/config.js";
const { contact } = site;
---

<BaseLayout
  title="Contact"
  description="Contact Instru-Met Corporation — phone, email, fax, and our service and production managers."
>
  <section class="section section--muted">
    <div class="site-container page-header">
      <p class="eyebrow">Contact</p>
      <h1 class="page-header__title">Talk to our engineers</h1>
      <p class="page-header__intro">
        Schedule a calibration, request a repair, or ask about remanufactured
        equipment. We typically respond in under 24 hours.
      </p>
    </div>
  </section>

  <section>
    <div class="site-container contact-grid">
      {/* Details */}
      <div>
        <div class="detail-grid">
          <div class="detail-grid__cell">
            <p class="detail-grid__label">Phone</p>
            <a href={contact.phoneHref} class="detail-grid__value">{contact.phone}</a>
          </div>
          <div class="detail-grid__cell">
            <p class="detail-grid__label">Fax</p>
            <p class="detail-grid__value">{contact.fax}</p>
          </div>
          <div class="detail-grid__cell">
            <p class="detail-grid__label">Email</p>
            <a href={`mailto:${contact.email}`} class="detail-grid__value">{contact.email}</a>
          </div>
          <div class="detail-grid__cell">
            <p class="detail-grid__label">Address</p>
            <address class="detail-grid__value">
              {contact.address.street}<br />
              {contact.address.city}, {contact.address.state} {contact.address.zip}
            </address>
          </div>
        </div>

        <h2 class="eyebrow contacts-title">Contacts</h2>
        <ul class="contacts">
          {
            site.people.map((p) => (
              <li>
                <div>
                  <p class="contacts__name">{p.name}</p>
                  <p class="contacts__role">{p.role}</p>
                </div>
                <a href={`mailto:${p.email}`} class="contacts__email">{p.email}</a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Simple message form — wired for Netlify Forms (progressive; static build). */}
      <div class="form-panel">
        <h2 class="form-panel__title">Send us a message</h2>
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="form"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="is-hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>
          <div>
            <label for="name" class="form__label">Name</label>
            <input id="name" name="name" type="text" required class="form__input" />
          </div>
          <div>
            <label for="email" class="form__label">Email</label>
            <input id="email" name="email" type="email" required class="form__input" />
          </div>
          <div>
            <label for="message" class="form__label">Message</label>
            <textarea id="message" name="message" rows="5" required class="form__input"></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--md">
            Send message
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
