---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/icons/Icon.astro";

const industries = (await getCollection("industries", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Industries" description="Industries served by Instru-Met calibration and service.">
  <div class="container py-16 lg:py-20">
    <p class="eyebrow mb-3">Who We Serve</p>
    <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">Industries Served</h1>
    <ul class="mt-12 grid grid-cols-2 gap-px overflow-hidden border border-border bg-border sm:grid-cols-3 lg:grid-cols-4">
      {industries.map((industry) => (
        <li class="bg-background">
          <a href={`/industries/${industry.id}`} class="group flex items-center gap-4 p-6 transition-colors hover:bg-secondary">
            <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center text-primary">
              <Icon name={industry.data.icon} class="h-6 w-6" />
            </span>
            <span class="text-sm font-medium text-foreground group-hover:text-primary">{industry.data.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
