---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/utils";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title="News" description="Calibration guidance, equipment spotlights, and service updates.">
  <div class="container py-16 lg:py-20">
    <p class="eyebrow mb-3">Latest News</p>
    <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">News & Insights</h1>
    <ul class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
      {posts.map((post) => (
        <li>
          <a href={`/news/${post.id}`} class="group flex h-full flex-col border border-border bg-card transition-shadow hover:shadow-card-hover">
            <div class="aspect-[16/10] overflow-hidden bg-secondary">
              <img src={post.data.cover ?? "/images/post-calibration.svg"} alt={post.data.coverAlt} class="h-full w-full object-cover" loading="lazy" />
            </div>
            <div class="flex flex-1 flex-col p-6">
              <div class="mb-3 flex items-center gap-3 text-xs">
                <span class="bg-primary px-2 py-1 font-semibold uppercase tracking-wide text-primary-foreground">{post.data.category}</span>
                <time datetime={post.data.date.toISOString()} class="tabular text-muted-foreground">{formatDate(post.data.date)}</time>
              </div>
              <h2 class="text-lg font-semibold leading-snug tracking-tight group-hover:text-primary">{post.data.title}</h2>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">{post.data.excerpt}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
