---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const getStaticPaths = (async () => {
  const products = await getCollection("products", ({ data }) => !data.draft);
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}) satisfies GetStaticPaths;

const { product } = Astro.props;
const { Content } = await render(product);
---

<BaseLayout title={product.data.title} description={product.data.summary}>
  <article class="container py-16 lg:py-20">
    <a href="/products" class="text-sm font-semibold uppercase tracking-wide text-primary">&larr; All products</a>
    <h1 class="mt-4 max-w-3xl text-4xl font-semibold tracking-tight sm:text-5xl">{product.data.title}</h1>
    <p class="mt-4 max-w-2xl text-lg text-muted-foreground">{product.data.summary}</p>
    {product.data.standards.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-x-4 gap-y-1">
        {product.data.standards.map((s) => <span class="chip tabular text-sm">{s}</span>)}
      </div>
    )}
    {product.data.image && (
      <img src={product.data.image} alt={product.data.imageAlt} class="mt-8 aspect-[16/9] w-full object-cover" />
    )}
    <div class="prose-body mt-10 max-w-prose space-y-4 text-base leading-relaxed text-foreground/90">
      <Content />
    </div>
  </article>
</BaseLayout>
