---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Media from "@/components/Media.astro";
import Button from "@/components/ui/Button.astro";

const products = await getCollection("products");

// Ordered categories → matching the mega-menu anchors.
const categories = [
  { name: "Load Cells", id: "load-cells" },
  { name: "Grips & Fixtures", id: "grips-fixtures" },
  { name: "Load Frames", id: "load-frames" },
];

const byCategory = (cat) =>
  products
    .filter((p) => p.data.category === cat)
    .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Products"
  description="Load cells, grips & fixtures, and load frames — supplied, remanufactured, repaired, and calibrated by Instru-Met."
>
  {/* Page header */}
  <section class="section section--muted">
    <div class="site-container page-header">
      <p class="eyebrow">Products</p>
      <h1 class="page-header__title">
        Test equipment, built to keep testing
      </h1>
      <p class="page-header__intro">
        From load cells to complete remanufactured frames — supplied, serviced,
        and verified so your lab keeps running.
      </p>
      <nav class="page-header__nav" aria-label="Product categories">
        {
          categories.map((c) => (
            <a href={`#${c.id}`} class="pill">
              {c.name}
            </a>
          ))
        }
      </nav>
    </div>
  </section>

  {
    categories.map((cat) => (
      <section id={cat.id} class="section section--anchor">
        <div class="site-container section-inner">
          <h2 class="section-title--sm">{cat.name}</h2>
          <div class="card-grid card-grid--spaced">
            {byCategory(cat.name).map((product) => (
              <article class="card">
                <div class="card__media">
                  <Media
                    src={product.data.image}
                    alt={product.data.name}
                    label={`${product.data.name} photo`}
                  />
                </div>
                <div class="card__body">
                  <h3 class="card__title">{product.data.name}</h3>
                  <p class="card__text">{product.data.summary}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <section class="cta-band cta-band--muted">
    <div class="site-container cta-band__inner">
      <p class="cta-band__text">Not sure which configuration you need?</p>
      <Button href="/contact">Talk to an engineer</Button>
    </div>
  </section>
</BaseLayout>
