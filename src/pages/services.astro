---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Media from "@/components/Media.astro";
import Button from "@/components/ui/Button.astro";

const equipment = [
  "Tensile Testers",
  "Pull Testers",
  "Universal Test Machines",
  "Strand Testers",
  "Creep Testers",
  "Stress Rupture Testers",
  "Compression Testers",
  "Fatigue Testers",
  "Peel / Adhesion Testers",
];

const forceStandards = [
  "ASTM E4 — Tension & Compression",
  "ISO 7500 — Tension & Compression",
  "ASTM E74 & ISO 376 — Load Cells",
];
const otherStandards = [
  "ASTM E83 — Extensometer / Strain",
  "ISO 9513 — Extensometer",
  "ASTM E2309 — Crosshead Displacement",
  "ASTM E2658 — Crosshead Speed",
];

const repairItems = [
  "Test frames (on-site and in-lab)",
  "Load cells — universal, canister, S-beam, single-point, pancake",
  "Extensometers, strain gauges & digital linear gauges",
  "Grips, fixtures & crosshead control units",
  "Load-cell amplifiers & console parts",
  "Temperature chambers",
];
const repairBrands = ["Instron", "MTS", "Tinius Olsen", "United", "Interface"];
---

<BaseLayout
  title="Services"
  description="Accredited calibration/verification and on-site repair for tensile, compression, and force-measuring equipment."
>
  {/* Page header */}
  <section class="border-b border-border bg-muted">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <p class="text-sm font-semibold tracking-wide text-accent">Services</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
        Calibration, verification &amp; repair
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
        A2LA-accredited and NIST-traceable — delivered on-site by our engineers
        or in our Union, NJ laboratory.
      </p>
      <nav class="mt-8 flex flex-wrap gap-3" aria-label="Services">
        <a href="#calibration" class="rounded-full border border-input bg-background px-5 py-2 text-sm font-medium text-foreground hover:border-accent hover:text-accent">Calibration / Verification</a>
        <a href="#repair" class="rounded-full border border-input bg-background px-5 py-2 text-sm font-medium text-foreground hover:border-accent hover:text-accent">Repair</a>
      </nav>
    </div>
  </section>

  {/* Calibration */}
  <section id="calibration" class="scroll-mt-32 border-b border-border">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:px-8 lg:py-24">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-foreground">
          Calibration / Verification
        </h2>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground">
          Instru-Met offers on-site calibration for tensile testers, compression
          testers, and force-measuring equipment. Our force calibration capacity
          ranges from 0.02 pounds force up to 120,000 pounds in compression and
          tension, serving customers globally with both small and large hydraulic
          machines. All calibrations maintain traceability to NIST and include
          preventive-maintenance checks during the visit.
        </p>

        <h3 class="mt-8 text-sm font-semibold tracking-wide text-accent">Force calibration</h3>
        <ul class="mt-3 space-y-1.5 text-sm text-muted-foreground">
          {forceStandards.map((s) => <li>{s}</li>)}
        </ul>

        <h3 class="mt-6 text-sm font-semibold tracking-wide text-accent">Displacement, strain & speed</h3>
        <ul class="mt-3 space-y-1.5 text-sm text-muted-foreground">
          {otherStandards.map((s) => <li>{s}</li>)}
        </ul>

        <p class="mt-6 text-sm text-muted-foreground">
          Additional scope: temperature calibration and dimensional linear
          measurement (calipers, gauges, micrometers). Quality system compliant
          with ISO/IEC 17025 &amp; ANSI/NCSL Z540-1.
        </p>
      </div>

      <div>
        <div class="aspect-[4/3] overflow-hidden border border-border">
          <Media src="/images/calibration.jpg" alt="ASTM calibration of a testing machine" label="calibration photo" />
        </div>
        <div class="mt-6 border border-border bg-card p-6">
          <h3 class="text-sm font-semibold text-foreground">Equipment we calibrate</h3>
          <ul class="mt-3 grid grid-cols-2 gap-x-6 gap-y-1.5 text-sm text-muted-foreground">
            {equipment.map((e) => <li>{e}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* Repair */}
  <section id="repair" class="scroll-mt-32 border-b border-border bg-muted">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:px-8 lg:py-24">
      <div class="order-last lg:order-first">
        <div class="aspect-[4/3] overflow-hidden border border-border">
          <Media src="/images/repair-tensile-tester.jpg" alt="Tensile tester repair" label="repair photo" />
        </div>
        <div class="mt-6 border border-border bg-background p-6">
          <h3 class="text-sm font-semibold text-foreground">Brands we service</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {repairBrands.map((b) => (
              <span class="rounded-full border border-input px-3 py-1 text-xs font-medium text-muted-foreground">{b}</span>
            ))}
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-foreground">Repair</h2>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground">
          Instru-Met repairs tensile and compression testers on-site as well as in
          our laboratory. Field service engineers perform on-site repairs when
          possible; for complex issues, components ship to our Union, NJ facility
          where technicians use advanced test equipment and an extensive parts
          inventory. Response time is typically less than 24 hours, and repairs
          can be returned with A2LA-accredited ASTM E4 or ISO 7500 verification.
        </p>
        <h3 class="mt-8 text-sm font-semibold tracking-wide text-accent">What we repair</h3>
        <ul class="mt-3 space-y-1.5 text-sm text-muted-foreground">
          {repairItems.map((r) => <li>{r}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto flex max-w-7xl flex-col items-start gap-4 px-4 py-14 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p class="text-lg font-medium text-foreground">Need a calibration scheduled or a machine looked at?</p>
      <Button href="/contact">Request service</Button>
    </div>
  </section>
</BaseLayout>
